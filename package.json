{
  "name": "querier-ts",
  "version": "1.0.2",
  "description": "Query tool for analysing arrays of objects",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*"
  ],
  "scripts": {
    "test": "jest --config jest.config.ts",
    "test:cov": "jest --config jest.config.ts --coverage",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm test && pnpm lint",
    "preversion": "pnpm lint",
    "version": "pnpm format && git add -A src",
    "postversion": "git push && git push --tags"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luizfilipezs/query-ts.git"
  },
  "keywords": [
    "query",
    "data filtering"
  ],
  "author": {
    "name": "Luiz Filipe da Silva",
    "email": "filipeluiz.bs@gmail.com",
    "url": "https://blogdolipe.com.br"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/luizfilipezs/query-ts/issues"
  },
  "homepage": "https://github.com/luizfilipezs/query-ts#readme",
  "dependencies": {
    "utility-types": "^3.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
